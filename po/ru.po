msgid "Agent needs your input"
msgstr "Агент ждёт вашего ответа"

msgid "Session “%1” is waiting for your answer"
msgstr "Сессия «%1» ждёт вашего ответа"

msgid "Agent finished"
msgstr "Агент закончил"

msgid "Session “%1” is idle again"
msgstr "Сессия «%1» снова свободна"

msgid "just now"
msgstr "только что"

