msgstr "ждёт твоего ответа"

msgid "working"
msgstr "работает"

msgid "Yes"
msgstr "Да"

msgid "No"
msgstr "Нет"

msgid "Send “y” + Enter"
msgstr "Отправить «y» + Enter"

msgid "Send “n” + Enter"
msgstr "Отправить «n» + Enter"

msgid "Send Enter"
msgstr "Отправить Enter"

msgid "Configure…"
msgstr "Настроить…"

msgid "Settings"
msgstr "Настройки"

msgid "Back"
msgstr "Назад"

msgid "Add to desktop"
msgstr "Добавить на рабочий стол"

msgid "Put it on your desktop"
msgstr "Размести на рабочем столе"

msgid "Drop TmuxPad on the desktop for a big, always-on mission-control dashboard. In a panel it stays a compact icon with a badge — use both!"
msgstr "Помести TmuxPad на рабочий стол — получишь большой постоянный дашборд. На панели он остаётся компактной иконкой с бейджем — используй оба варианта!"

msgid "Open tmux in:"
msgstr "Открывать tmux в:"

msgid "Automatic (%1)"
msgstr "Автоматически (%1)"

msgid "Automatic"
msgstr "Автоматически"

msgid "Custom command…"
msgstr "Своя команда…"

msgid "Custom command:"
msgstr "Своя команда:"

msgid "%1 is replaced with the session name."
msgstr "%1 заменяется на имя сессии."

msgid "No known terminal found — pick “Custom command…” and enter your own."
msgstr "Известный терминал не найден — выберите «Своя команда…» и впишите свою."

msgid "Detected terminals are listed automatically. “Automatic” uses the first one."
msgstr "Найденные терминалы добавляются автоматически. «Автоматически» берёт первый."

msgid "Terminal"
msgstr "Терминал"

msgid "Updates"
msgstr "Обновление"

msgid "Agent processes"
msgstr "Процессы агентов"

msgid "Status detection"
msgstr "Определение статуса"

msgid "Sessions whose foreground process matches one of these names are treated as AI agents."
msgstr "Сессии, чей активный процесс совпадает с одним из этих имён, считаются AI-агентами."

msgid "One regex per line, matched against the last visible lines of each session."
msgstr "По одному regex на строку, сверяется с последними видимыми строками сессии."

msgid "“Waiting for input” patterns"
msgstr "Паттерны «ждёт ввода»"

msgid "“Working” patterns"
msgstr "Паттерны «работает»"

msgid "A Braille spinner (⠋⠙⠹…) at the start of the pane title also counts as “working” — Claude Code sets it automatically."
msgstr "Брайль-спиннер (⠋⠙⠹…) в начале заголовка панели тоже означает «работает» — Claude Code ставит его автоматически."
