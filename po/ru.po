msgstr "%1 мин"

msgid "%1 h"
msgstr "%1 ч"

msgid "%1 d"
msgstr "%1 дн"

msgid "General"
msgstr "Общие"

msgid "AI Agents"
msgstr "AI-агенты"

msgid "Needs you"
msgstr "Нужен ты"

msgid "Working"
msgstr "Работают"

msgid "Idle"
msgstr "Простаивают"

